{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artbox Render Project",
  "description": "Schema for artbox render project YAML configuration.",
  "type": "object",
  "required": ["name", "global", "source", "slides"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name."
    },
    "output": {
      "type": "string",
      "description": "Default output directory (overridden by CLI --output)."
    },
    "global": {
      "type": "object",
      "description": "Global settings applied to all slides.",
      "properties": {
        "audio": {
          "type": "object",
          "description": "Default audio/TTS parameters.",
          "properties": {
            "language": {
              "type": "string",
              "description": "Language for TTS (e.g. 'en', 'spanish', 'pt')."
            },
            "voice-id": {
              "type": "string",
              "description": "Specific edge-tts voice ID (e.g. 'en-US-AriaNeural'). Overrides random voice selection."
            },
            "gender": {
              "type": "string",
              "enum": ["male", "female"],
              "description": "Voice gender for TTS."
            },
            "volume": {
              "type": "number",
              "description": "Volume multiplier (1.0 = normal)."
            },
            "pitch": {
              "type": "number",
              "description": "Pitch multiplier (1.0 = normal)."
            },
            "speed": {
              "type": "number",
              "description": "Speed multiplier (1.0 = normal)."
            }
          },
          "additionalProperties": false
        },
        "pause-after": {
          "type": "number",
          "description": "Default pause in seconds after each slide."
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "description": "Source type configuration.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["image", "pdf"],
          "description": "Source type: 'image' (individual image files) or 'pdf' (pages from a PDF)."
        },
        "path": {
          "type": "string",
          "description": "Path to the PDF file (required when type is 'pdf')."
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": { "type": { "const": "pdf" } }
      },
      "then": {
        "required": ["path"]
      }
    },
    "slides": {
      "type": "array",
      "description": "List of slide definitions.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide", "background"],
        "properties": {
          "slide": {
            "type": "integer",
            "description": "Slide number (for ordering and identification)."
          },
          "background": {
            "type": "object",
            "description": "Background image or PDF page for this slide.",
            "properties": {
              "path": {
                "type": "string",
                "description": "Path to the background image (for image source type)."
              },
              "page": {
                "type": "integer",
                "description": "PDF page number to use (for pdf source type)."
              }
            },
            "additionalProperties": false
          },
          "audio": {
            "type": "object",
            "description": "Audio configuration for this slide.",
            "properties": {
              "text": {
                "type": "string",
                "description": "Text to convert to speech via TTS."
              },
              "voice-id": {
                "type": "string",
                "description": "Per-slide edge-tts voice ID override."
              },
              "path": {
                "type": "string",
                "description": "Path to a pre-recorded audio file."
              },
              "volume": {
                "type": "number",
                "description": "Per-slide volume override."
              },
              "pitch": {
                "type": "number",
                "description": "Per-slide pitch override."
              },
              "speed": {
                "type": "number",
                "description": "Per-slide speed override."
              },
              "pause-after": {
                "type": "number",
                "description": "Per-slide pause override (seconds)."
              }
            },
            "additionalProperties": false
          },
          "pause-after": {
            "type": "number",
            "description": "Pause in seconds after this slide (overrides global)."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
