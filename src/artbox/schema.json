{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artbox Render Project",
  "description": "Schema for artbox render project YAML configuration.",
  "type": "object",
  "required": ["name", "source", "slides"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name."
    },
    "output": {
      "type": "string",
      "description": "Default output directory (overridden by CLI --output)."
    },
    "audio": {
      "type": "object",
      "description": "Global audio settings and engine configuration.",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["edge-tts", "gtts", "openai-tts"],
          "description": "Audio TTS engine to use."
        },
        "instruction": {
          "type": "string",
          "description": "Path to a text file containing voice instructions."
        },
        "defaults": {
          "type": "object",
          "description": "Default audio settings that can be overridden by individual slides.",
          "properties": {
            "language": {
              "type": "string",
              "description": "Language for TTS (e.g. 'en', 'spanish', 'pt')."
            },
            "model": {
              "type": "string",
              "description": "Specific TTS model to use (e.g. 'tts-1', 'gpt-4o-mini-tts')."
            },
            "voice-id": {
              "type": "string",
              "description": "Specific edge-tts voice ID (e.g. 'en-US-AriaNeural'). Overrides random voice selection."
            },
            "gender": {
              "type": "string",
              "enum": ["male", "female"],
              "description": "Voice gender for TTS."
            },
            "volume": {
              "type": "number",
              "description": "Volume multiplier (1.0 = normal)."
            },
            "pitch": {
              "type": "number",
              "description": "Pitch multiplier (1.0 = normal)."
            },
            "speed": {
              "type": "number",
              "description": "Speed multiplier (1.0 = normal)."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "video": {
      "type": "object",
      "description": "Global video settings and engine configuration.",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["ffmpeg", "moviepy"],
          "description": "Video rendering engine to use."
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "description": "Source type configuration.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["image", "pdf"],
          "description": "Source type: 'image' (individual image files) or 'pdf' (pages from a PDF)."
        },
        "path": {
          "type": "string",
          "description": "Path to the PDF file (required when type is 'pdf')."
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": { "type": { "const": "pdf" } }
      },
      "then": {
        "required": ["path"]
      }
    },
    "slides": {
      "type": "object",
      "description": "Slides configuration and list.",
      "properties": {
        "defaults": {
          "type": "object",
          "properties": {
            "transitions": {
              "type": "object",
              "properties": {
                "pause-after": {
                  "type": "number",
                  "description": "Default pause in seconds after each slide."
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "items": {
          "type": "array",
          "description": "List of slide definitions.",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["slide", "background"],
            "properties": {
              "slide": {
                "type": "integer",
                "description": "Slide number (for ordering and identification)."
              },
              "background": {
                "type": "object",
                "description": "Background image or PDF page for this slide.",
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "Path to the background image (for image source type)."
                  },
                  "page": {
                    "type": "integer",
                    "description": "PDF page number to use (for pdf source type)."
                  }
                },
                "additionalProperties": false
              },
              "audio": {
                "type": "object",
                "description": "Audio configuration for this slide.",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text to convert to speech via TTS."
                  },
                  "model": {
                    "type": "string",
                    "description": "Specific TTS model to use (e.g. 'tts-1', 'gpt-4o-mini-tts')."
                  },
                  "voice-id": {
                    "type": "string",
                    "description": "Per-slide edge-tts voice ID override."
                  },
                  "path": {
                    "type": "string",
                    "description": "Path to a pre-recorded audio file."
                  },
                  "volume": {
                    "type": "number",
                    "description": "Per-slide volume override."
                  },
                  "pitch": {
                    "type": "number",
                    "description": "Per-slide pitch override."
                  },
                  "speed": {
                    "type": "number",
                    "description": "Per-slide speed override."
                  },
                  "pause-after": {
                    "type": "number",
                    "description": "Per-slide pause override (seconds)."
                  }
                },
                "additionalProperties": false
              },
              "pause-after": {
                "type": "number",
                "description": "Pause in seconds after this slide (overrides global)."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["items"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
